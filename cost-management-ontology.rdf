<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/cost-management/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/cost-management/">

    <owl:Ontology rdf:about="http://example.org/ontology/cost-management/">
        <rdfs:label>Azure Cost Management</rdfs:label>
        <rdfs:comment>Azure cost breakdown: subscriptions, resource groups, resources, meters, and daily costs</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/cost-management/Subscription">
        <rdfs:label>Subscription</rdfs:label>
        <rdfs:comment>Azure subscription — the top-level billing container. All resources and costs roll up to a subscription.</rdfs:comment>
        <ont:icon>🔑</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cost-management/ResourceGroup">
        <rdfs:label>ResourceGroup</rdfs:label>
        <rdfs:comment>Logical container that groups related Azure resources for management and billing. Resources in the same group are typically deployed and managed together.</rdfs:comment>
        <ont:icon>📁</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cost-management/Resource">
        <rdfs:label>Resource</rdfs:label>
        <rdfs:comment>An individual Azure resource instance (VM, storage account, database, etc.) identified by its full Azure Resource Manager ID.</rdfs:comment>
        <ont:icon>⚙️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cost-management/CostRecord">
        <rdfs:label>CostRecord</rdfs:label>
        <rdfs:comment>A daily cost line item representing the pre-tax cost incurred by a specific resource on a specific date. This is the fact table of the cost model.</rdfs:comment>
        <ont:icon>💰</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cost-management/MeterCategory">
        <rdfs:label>MeterCategory</rdfs:label>
        <rdfs:comment>Billing meter classification. MeterCategory is the top-level service grouping (e.g. Virtual Machines, Storage). MeterSubCategory provides finer detail (e.g. D-Series, General Block Blob). MeterName is the specific meter (e.g. D4s v3, LRS Data Stored).</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cost-management/Service">
        <rdfs:label>Service</rdfs:label>
        <rdfs:comment>The consumed Azure service that emitted the usage record (ConsumedService field, e.g. Microsoft.Compute, Microsoft.Storage) combined with the charge type (Usage, Purchase, Refund).</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#00BCF2</ont:color>
    </owl:Class>

    <!-- ============================== -->
    <!-- Data Properties — Subscription -->
    <!-- ============================== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/subscription_subscriptionId">
        <rdfs:label>subscriptionId</rdfs:label>
        <rdfs:comment>Unique GUID identifier for the Azure subscription</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Subscription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/subscription_subscriptionName">
        <rdfs:label>subscriptionName</rdfs:label>
        <rdfs:comment>Human-readable display name of the Azure subscription</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Subscription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ================================ -->
    <!-- Data Properties — ResourceGroup  -->
    <!-- ================================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/rg_resourceGroupId">
        <rdfs:label>resourceGroupId</rdfs:label>
        <rdfs:comment>Composite key: subscriptionId/resourceGroupName — uniquely identifies the resource group within a subscription</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/ResourceGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/rg_resourceGroupName">
        <rdfs:label>resourceGroupName</rdfs:label>
        <rdfs:comment>Name of the resource group (case-insensitive in Azure)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/ResourceGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/rg_subscriptionId">
        <rdfs:label>subscriptionId</rdfs:label>
        <rdfs:comment>Foreign key linking the resource group to its parent subscription</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/ResourceGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ========================== -->
    <!-- Data Properties — Resource -->
    <!-- ========================== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/res_resourceId">
        <rdfs:label>resourceId</rdfs:label>
        <rdfs:comment>Full Azure Resource Manager path (e.g. /subscriptions/.../resourceGroups/.../providers/Microsoft.Compute/virtualMachines/myvm)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/res_resourceType">
        <rdfs:label>resourceType</rdfs:label>
        <rdfs:comment>Azure resource provider type (e.g. Microsoft.Compute/virtualMachines, Microsoft.Storage/storageAccounts)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/res_resourceGroupId">
        <rdfs:label>resourceGroupId</rdfs:label>
        <rdfs:comment>Foreign key linking the resource to its parent resource group</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/res_resourceGroupName">
        <rdfs:label>resourceGroupName</rdfs:label>
        <rdfs:comment>Name of the resource group this resource belongs to</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/res_location">
        <rdfs:label>location</rdfs:label>
        <rdfs:comment>Azure region where the resource is deployed (e.g. eastus, westeurope, southeastasia)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ============================= -->
    <!-- Data Properties — CostRecord  -->
    <!-- ============================= -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_costRecordId">
        <rdfs:label>costRecordId</rdfs:label>
        <rdfs:comment>Auto-generated unique identifier for each cost line item</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_subscriptionId">
        <rdfs:label>subscriptionId</rdfs:label>
        <rdfs:comment>Foreign key to the subscription that was billed</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_resourceGroupId">
        <rdfs:label>resourceGroupId</rdfs:label>
        <rdfs:comment>Foreign key to the resource group</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_resourceId">
        <rdfs:label>resourceId</rdfs:label>
        <rdfs:comment>Foreign key to the Azure resource that incurred the cost</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_meterId">
        <rdfs:label>meterId</rdfs:label>
        <rdfs:comment>Foreign key to the billing meter category</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_serviceId">
        <rdfs:label>serviceId</rdfs:label>
        <rdfs:comment>Foreign key to the consumed service</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_usageDate">
        <rdfs:label>usageDate</rdfs:label>
        <rdfs:comment>The date the cost was incurred (usage date or purchase date)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_preTaxCost">
        <rdfs:label>preTaxCost</rdfs:label>
        <rdfs:comment>Cost of the charge before credits or taxes, in billing currency. Computed as ResourceRate x UsageQuantity.</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_quantity">
        <rdfs:label>quantity</rdfs:label>
        <rdfs:comment>Number of units consumed (e.g. hours of VM time, GB of storage)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_unitOfMeasure">
        <rdfs:label>unitOfMeasure</rdfs:label>
        <rdfs:comment>Unit for billing (e.g. 1 Hour, 1 GB/Month, 10K Transactions)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_chargeType">
        <rdfs:label>chargeType</rdfs:label>
        <rdfs:comment>Whether the charge is Usage (consumption), Purchase (reservation/savings plan buy), or Refund</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_location">
        <rdfs:label>location</rdfs:label>
        <rdfs:comment>Azure region where the usage occurred</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/cr_currency">
        <rdfs:label>Currency</rdfs:label>
        <rdfs:comment>Billing currency code (e.g. USD, EUR, GBP)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ================================ -->
    <!-- Data Properties — MeterCategory  -->
    <!-- ================================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/mc_meterId">
        <rdfs:label>meterId</rdfs:label>
        <rdfs:comment>MD5 hash of meterCategory|meterSubCategory|meterName — synthetic unique key for the meter</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/MeterCategory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/mc_meterCategory">
        <rdfs:label>meterCategory</rdfs:label>
        <rdfs:comment>Top-level billing classification (e.g. Virtual Machines, Storage, Networking, Azure App Service)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/MeterCategory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/mc_meterSubCategory">
        <rdfs:label>meterSubCategory</rdfs:label>
        <rdfs:comment>Finer billing classification within a category (e.g. D-Series for VMs, General Block Blob for Storage)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/MeterCategory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/mc_meterName">
        <rdfs:label>meterName</rdfs:label>
        <rdfs:comment>Specific meter name (e.g. D4s v3, LRS Data Stored, Standard Static Public IP)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/MeterCategory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/mc_unitOfMeasure">
        <rdfs:label>unitOfMeasure</rdfs:label>
        <rdfs:comment>Unit of billing for this meter (e.g. 1 Hour, 1 GB/Month)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/MeterCategory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ========================== -->
    <!-- Data Properties — Service  -->
    <!-- ========================== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/svc_serviceId">
        <rdfs:label>serviceId</rdfs:label>
        <rdfs:comment>MD5 hash of serviceName|chargeType — synthetic unique key</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Service"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/svc_serviceName">
        <rdfs:label>serviceName</rdfs:label>
        <rdfs:comment>The Azure service that emitted the usage (ConsumedService field, e.g. Microsoft.Compute, Microsoft.Storage, Microsoft.Sql)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Service"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/cost-management/svc_chargeType">
        <rdfs:label>chargeType</rdfs:label>
        <rdfs:comment>Whether the charge is Usage, Purchase, or Refund</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Service"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ========================== -->
    <!-- Object Properties (Relationships) -->
    <!-- ========================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cost-management/has_resource_group">
        <rdfs:label>has_resource_group</rdfs:label>
        <rdfs:comment>A subscription contains one or more resource groups</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Subscription"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cost-management/ResourceGroup"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cost-management/contains_resource">
        <rdfs:label>contains_resource</rdfs:label>
        <rdfs:comment>A resource group contains one or more resources</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/ResourceGroup"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cost-management/Resource"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cost-management/incurs_cost">
        <rdfs:label>incurs_cost</rdfs:label>
        <rdfs:comment>A resource generates one or more daily cost records</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Resource"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cost-management/billed_under">
        <rdfs:label>billed_under</rdfs:label>
        <rdfs:comment>A cost record is classified under a specific billing meter</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cost-management/MeterCategory"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cost-management/consumed_by">
        <rdfs:label>consumed_by</rdfs:label>
        <rdfs:comment>A cost record was generated by a specific Azure service</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cost-management/Service"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/cost-management/billed_by">
        <rdfs:label>billed_by</rdfs:label>
        <rdfs:comment>A subscription is billed through cost records (direct link for aggregation queries)</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/cost-management/Subscription"/>
        <rdfs:range rdf:resource="http://example.org/ontology/cost-management/CostRecord"/>
    </owl:ObjectProperty>

</rdf:RDF>

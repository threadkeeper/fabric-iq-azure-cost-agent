          "position": { "x": 20, "y": 15, "z": 3000, "width": 240, "height": 70, "tabOrder": 0 },
          "visual": {
            "visualType": "slicer",
            "query": {
              "queryState": {
                "Values": {
                  "projections": [
                    {
                      "field": {
                        "Column": {
                          "Expression": { "SourceRef": { "Entity": "subscription" } },
                          "Property": "subscriptionName"
                        }
                      },
                      "queryRef": "subscription.subscriptionName",
                      "active": true
                    }
                  ]
                }
              }
            },
            "objects": {
              "data": [{ "properties": { "mode": { "expr": { "Literal": { "Value": "'Dropdown'" } } } } }]
            },
            "vcObjects": {
              "title": [{ "properties": { "text": { "expr": { "Literal": { "Value": "'Subscription'" } } }, "show": { "expr": { "Literal": { "Value": "true" } } } } }]
            }
          }
        },
        {
